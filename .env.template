# Ultrathink Environment Configuration
# Copy this file to .env and fill in your actual API keys

# Anthropic Claude API Key
# Get your key at: https://console.anthropic.com/
CLAUDE_API_KEY=your-anthropic-api-key-here

# Google Cloud Project ID
# Get your project ID at: https://console.cloud.google.com/
GOOGLE_PROJECT_ID=your-gcp-project-id

# AWS Region for Bedrock
# Default is us-east-1, change if you're using a different region
AWS_REGION=us-east-1

# Optional: AWS Credentials (if not using default profile)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
